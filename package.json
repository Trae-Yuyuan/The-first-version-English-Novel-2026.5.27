{
  "name": "emotion-ai-ui",
  "private": true,
  "version": "0.0.0",

  "main": "electron/main.js",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "electron": "electron electron/main.js",
    "dev:desktop": "concurrently \"pnpm dev\" \"wait-on http://localhost:5173 && electron electron/main.js\""
  },

  "build": {
    "appId": "com.emotionai.app",
    "productName": "EmotionAI",

    "directories": {
      "output": "dist"
    },

    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "electron/backend",
        "to": "backend"
      }
    ],

    "win": {
      "target": "nsis"
    }
  },

  "dependencies": {
    "@fontsource/press-start-2p": "^5.2.7",
    "@tailwindcss/vite": "^4.3.0",
    "nes.css": "^2.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "tailwindcss": "^4.3.0"
  },

  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",

    "concurrently": "^9.2.1",
    "electron": "^38.8.6",
    "wait-on": "^9.0.10",

    "vite": "^8.0.14",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0"
  }
}