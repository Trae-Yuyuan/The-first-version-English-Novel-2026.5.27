{
  "name": "emotion-ai-ui",

  "private": true,

  "version": "0.0.0",

  "type": "module",

  "main": "electron/main.js",

  "scripts": {

    "dev": "vite",

    "build": "vite build",

    "lint": "eslint .",

    "preview": "vite preview",

    "electron": "electron electron/main.js",

    "dev:desktop": "concurrently \"pnpm dev\" \"wait-on http://localhost:5173 && electron electron/main.js\"",

    "build:desktop": "electron-builder"
