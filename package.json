{
  "name": "emotion-ai-ui",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",

  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:desktop": "concurrently \"pnpm dev\" \"wait-on http://localhost:5173 && npx electron electron/main.js\"",
    "build": "vite build"
  },

  "build": {
    "appId": "com.emotionai.app",
    "productName": "EmotionAI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },

  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "nes.css": "^2.3.0",
    "@fontsource/press-start-2p": "^5.2.7"
  },

  "devDependencies": {
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",

    "electron": "^38.8.6",
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.10",

    "tailwindcss": "^3.4.19",
    "postcss": "^8.5.15",
    "autoprefixer": "^10.4.19"
  }
}