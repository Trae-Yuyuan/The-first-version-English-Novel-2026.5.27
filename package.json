    "nes.css": "^2.3.0",

    "react": "^19.2.6",

    "react-dom": "^19.2.6",

    "react-dropzone": "^15.0.0",

    "tailwindcss": "^4.3.0"
  },

  "devDependencies": {

    "@eslint/js": "^10.0.1",

    "@types/react": "^19.2.14",

    "@types/react-dom": "^19.2.3",

    "@vitejs/plugin-react": "^6.0.1",

    "concurrently": "^9.2.1",

    "electron": "^38.1.0",

    "electron-builder": "^26.8.1",

    "eslint": "^10.3.0",

    "eslint-plugin-react-hooks": "^7.1.1",

    "eslint-plugin-react-refresh": "^0.5.2",

