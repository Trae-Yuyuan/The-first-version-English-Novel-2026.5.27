{
  "name": "emotion-ai-ui",
  "version": "0.0.0",
  "private": true,
  "main": "electron/main.js",
  "description": "Emotion AI Desktop App",
  "author": "emotion-ai",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron electron/main.js",
    "dev:desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron electron/main.js\"",
    "build:desktop": "electron-builder"
  },

  "build": {
    "appId": "com.emotionai.app",
    "productName": "EmotionAI",

    "directories": {
      "output": "dist"
    },

    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],

    "win": {
      "target": "nsis"
    },

    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },

    "publish": null
  },

  "dependencies": {
    "@fontsource/press-start-2p": "^5.2.7",
    "nes.css": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "tailwindcss": "^3.4.0"
  },

  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.0",
    "wait-on": "^9.0.10"
  }
}